# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/oktatas?schema=public"
# On Supabase, DIRECT_URL is the direct connection (port 5432) and DATABASE_URL is the pooler (port 6543).
# On localhost, both point to the same DB.
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/oktatas?schema=public"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Mobile API (for Expo to reach Next.js)
EXPO_PUBLIC_API_URL="http://localhost:3000"
