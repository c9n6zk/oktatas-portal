{
  "expo": {
    "name": "Padtárs",
    "slug": "padtars-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "oktatasportal",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "hu.demo.oktatasportal",
      "infoPlist": {
        "NSCameraUsageDescription": "Profilkép és dokumentumok rögzítése",
        "NSLocationWhenInUseUsageDescription": "Jelenléti adatok jelölése a kampuszon",
        "NSPhotoLibraryUsageDescription": "Képek kiválasztása"
      }
    },
    "android": {
      "package": "hu.demo.oktatasportal",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#8b5cf6"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Profilkép és dokumentumok rögzítése"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Jelenléti adatok rögzítése"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#8b5cf6"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
