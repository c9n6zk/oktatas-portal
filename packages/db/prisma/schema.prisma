// Prisma schema — high-school education portal.
// Domain: Class (Osztály), Subject (Tárgy), SubjectAssignment (year-class-teacher-subject),
//          Grade (Jegy) with type and weight.

generator client {
  provider      = "prisma-client-js"
  // native = local Windows dev, rhel-openssl-3.0.x = Vercel serverless runtime
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum GradeType {
  ORAL      // felelés (default weight 1)
  TEST      // témazáró (default weight 3)
  HOMEWORK  // házi (default weight 1)
  MID_YEAR  // féléves jegy
  YEAR_END  // év végi jegy
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(STUDENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // School relations
  schoolClass       SchoolClass?        @relation("ClassStudents", fields: [classId], references: [id])
  classId           String?
  taughtAssignments SubjectAssignment[] @relation("TeacherAssignments")
  grades            Grade[]             @relation("StudentGrades")

  // NextAuth
  sessions Session[]
  accounts Account[]
}

model SchoolClass {
  id         String              @id @default(cuid())
  startYear  Int // pl. 2024
  identifier String // pl. "A"
  students   User[]              @relation("ClassStudents")
  assignments SubjectAssignment[]
  createdAt  DateTime            @default(now())

  @@unique([startYear, identifier])
}

model Subject {
  id          String              @id @default(cuid())
  code        String              @unique // pl. "MAT"
  name        String
  description String?
  bookTitle   String?
  lessons     String[]            @default([])
  assignments SubjectAssignment[]
  createdAt   DateTime            @default(now())
}

model SubjectAssignment {
  id          String      @id @default(cuid())
  year        Int // tanév kezdő éve (pl. 2025)
  subject     Subject     @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId   String
  schoolClass SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId     String
  teacher     User        @relation("TeacherAssignments", fields: [teacherId], references: [id])
  teacherId   String
  grades      Grade[]
  createdAt   DateTime    @default(now())

  @@unique([year, subjectId, classId])
}

model Grade {
  id           String            @id @default(cuid())
  student      User              @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String
  assignment   SubjectAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  value        Int // 1-5
  type         GradeType         @default(ORAL)
  weight       Int               @default(1)
  comment      String?
  givenAt      DateTime          @default(now())
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
