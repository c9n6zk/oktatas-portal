// Prisma schema — high-school education portal.
// Domain: Class (Osztály), Subject (Tárgy), SubjectAssignment (year-class-teacher-subject),
//          Grade (Jegy) with type and weight.

generator client {
  provider      = "prisma-client-js"
  // native = local Windows dev, rhel-openssl-3.0.x = Vercel serverless runtime
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum GradeType {
  ORAL      // felelés (default weight 1)
  TEST      // témazáró (default weight 3)
  HOMEWORK  // házi (default weight 1)
  MID_YEAR  // féléves jegy
  YEAR_END  // év végi jegy
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum PollAudience {
  ALL          // mindenki válaszolhat
  STUDENTS     // csak diákok
  INSTRUCTORS  // csak oktatók
  CLASS        // csak adott osztály diákjai (classId-vel)
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(STUDENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // School relations
  schoolClass       SchoolClass?        @relation("ClassStudents", fields: [classId], references: [id])
  classId           String?
  taughtAssignments SubjectAssignment[] @relation("TeacherAssignments")
  grades            Grade[]             @relation("StudentGrades")
  attendances       Attendance[]        @relation("StudentAttendance")
  eventsCreated     Event[]             @relation("EventCreator")
  groups            Group[]             @relation("GroupMembers")
  substituteFor     ScheduleEntry[]     @relation("SubstituteTeacher")
  pollsCreated      Poll[]              @relation("PollCreator")
  pollResponses     PollResponse[]      @relation("PollResponseUser")
  pushTokens        PushToken[]
  messagesSent      Message[]           @relation("MessageSender")
  messagesReceived  Message[]           @relation("MessageRecipient")

  // NextAuth
  sessions Session[]
  accounts Account[]
}

// Expo push notification token — egy user több eszközről is regisztrálhat.
model PushToken {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  token      String   @unique // ExponentPushToken[xxxxxxx]
  platform   String   @default("unknown") // "ios" | "android" | "web" | "unknown"
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([userId])
}

model SchoolClass {
  id         String              @id @default(cuid())
  startYear  Int // pl. 2024
  identifier String // pl. "A"
  students   User[]              @relation("ClassStudents")
  assignments SubjectAssignment[]
  polls      Poll[]
  createdAt  DateTime            @default(now())

  @@unique([startYear, identifier])
}

// Csoport — hallgatók egy alhalmaza (pl. nyelvi csoport, haladó matek).
// A csoport tantárgyhoz rendelhető, ugyanúgy mint az osztály.
model Group {
  id          String              @id @default(cuid())
  name        String              @unique
  description String?
  members     User[]              @relation("GroupMembers")
  assignments SubjectAssignment[]
  createdAt   DateTime            @default(now())
}

model Subject {
  id          String              @id @default(cuid())
  code        String              @unique // pl. "MAT"
  name        String
  description String?
  bookTitle   String?
  lessons     String[]            @default([])
  assignments SubjectAssignment[]
  createdAt   DateTime            @default(now())
}

model SubjectAssignment {
  id          String           @id @default(cuid())
  year        Int // tanév kezdő éve (pl. 2025)
  subject     Subject          @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId   String
  // Vagy osztály VAGY csoport — legalább az egyik kötelező (app-szintű validáció).
  schoolClass SchoolClass?     @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId     String?
  group       Group?           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId     String?
  teacher     User             @relation("TeacherAssignments", fields: [teacherId], references: [id])
  teacherId   String
  grades      Grade[]
  attendances Attendance[]     @relation("AssignmentAttendance")
  scheduleEntries ScheduleEntry[]
  createdAt   DateTime         @default(now())
}

// Heti órarend bejegyzés — egy SubjectAssignment-hez 0 vagy több ScheduleEntry tartozik.
model ScheduleEntry {
  id           String            @id @default(cuid())
  assignment   SubjectAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  dayOfWeek    DayOfWeek
  startTime    String            // "08:00" formátum
  endTime      String            // "08:45" formátum
  room         String?
  // Helyettesítő tanár — opcionális, ha valaki más helyettesít az adott órán
  substituteTeacher   User?   @relation("SubstituteTeacher", fields: [substituteTeacherId], references: [id])
  substituteTeacherId String?
  createdAt    DateTime          @default(now())
}

model Grade {
  id           String            @id @default(cuid())
  student      User              @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String
  assignment   SubjectAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  value        Int // 1-5
  type         GradeType         @default(ORAL)
  weight       Int               @default(1)
  comment      String?
  givenAt      DateTime          @default(now())
}

// Iskolai esemény (admin létrehoz, mindenki látja).
model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  createdBy   User     @relation("EventCreator", fields: [createdById], references: [id])
  createdById String
  createdAt   DateTime @default(now())
}

// Szavazás / kérdőív (admin létrehozza, célközönség szűkíthető).
model Poll {
  id          String         @id @default(cuid())
  question    String
  description String?
  audience    PollAudience   @default(ALL)
  // ha audience = CLASS, ez a classId határozza meg melyik osztálynak megy
  schoolClass SchoolClass?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  classId     String?
  createdBy   User           @relation("PollCreator", fields: [createdById], references: [id])
  createdById String
  options     PollOption[]
  responses   PollResponse[]
  closesAt    DateTime?
  createdAt   DateTime       @default(now())
}

model PollOption {
  id        String         @id @default(cuid())
  poll      Poll           @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId    String
  text      String
  order     Int            @default(0)
  responses PollResponse[]
}

model PollResponse {
  id        String     @id @default(cuid())
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollId    String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  optionId  String
  user      User       @relation("PollResponseUser", fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime   @default(now())

  @@unique([pollId, userId]) // egy user egy szavazásban egyszer szavaz
}

// Diák↔Oktató kétirányú üzenet. A küldő/címzett közti összes üzenet egy "thread".
model Message {
  id          String   @id @default(cuid())
  sender      User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId    String
  recipient   User     @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId String
  body        String
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, readAt])
}

// Jelenléti rögzítés (mobil GPS-szel) — opcionális innovation feature.
model Attendance {
  id           String            @id @default(cuid())
  student      User              @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String
  assignment   SubjectAssignment @relation("AssignmentAttendance", fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentId String
  present      Boolean           @default(true)
  recordedAt   DateTime          @default(now())
  // GPS koordináták ha mobilról rögzítve
  latitude     Float?
  longitude    Float?
  source       String            @default("manual") // "manual" | "gps" | "qr"
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
